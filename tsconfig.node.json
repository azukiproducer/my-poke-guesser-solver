{
  "compilerOptions": {
    "target": "ES2021",
    "lib": ["ES2021"],
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "strict": true,
    "types": ["node"]
  },
  "include": ["vite.config.ts", "scripts/**/*.ts", "src/lib/types.ts"]
}
